# Local stack defaults
TZ=America/New_York
MEMOS_PORT=5230
N8N_PORT=5678
QDRANT_PORT=6333
RSSHUB_PORT=1200
# Default mode uses the published RSSHub image. Local source builds use compose.rsshub-local.yaml.
RSSHUB_IMAGE=diygod/rsshub:latest
RSSHUB_LOCAL_IMAGE=ai-information-processor-rsshub:local
IM2MEMO_PORT=3000
COLLECTOR_WEB_PORT=8300
COLLECTOR_WEB_MANUAL_MEDIA_SUBMIT_URL=http://127.0.0.1:5678/webhook/6b8eaf7c41d2439a/manual-media-submit-webhook/aip/local/manual-media-submit
COLLECTOR_WEB_MANUAL_MEDIA_SUBMIT_TIMEOUT_SECONDS=1800
COLLECTOR_WEB_MANUAL_MEDIA_SUBMIT_DISPATCH_TIMEOUT_SECONDS=30
COLLECTOR_WEB_CALLBACK_BASE_URL=http://collector-web:8300
COLLECTOR_WEB_MANUAL_MEDIA_PRECHECK_TIMEOUT_SECONDS=10
COLLECTOR_WEB_QDRANT_BASE_URL=http://127.0.0.1:6333
COLLECTOR_WEB_QDRANT_COLLECTION=article_embeddings
COLLECTOR_WEB_QDRANT_TIMEOUT_SECONDS=30
COLLECTOR_WEB_MANUAL_SUBMISSION_HISTORY_LIMIT=12
COLLECTOR_WEB_CALIBRATION_COMPARE_API_BASE_URL=http://video-transcript-api:8000/api/model-compare
COLLECTOR_WEB_CALIBRATION_COMPARE_PUBLIC_BASE_URL=http://127.0.0.1:18080
COLLECTOR_WEB_CALIBRATION_COMPARE_CONTAINER_OUTPUT_DIR=/app/data/model_compare
COLLECTOR_WEB_CALIBRATION_COMPARE_LOCAL_OUTPUT_DIR=./deploy/data/video-transcript-api/model_compare
COLLECTOR_WEB_CALIBRATION_COMPARE_TIMEOUT_SECONDS=30
RSSHUB_PUPPETEER_WS_ENDPOINT=
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string
OBSIDIAN_VAULT_PATH=./vault
OBSIDIAN_INBOX_DIR=00_Inbox
OBSIDIAN_DAILY_DIR=10_Daily
# Baseline workflow still reads feed sources from env JSON; migrate to file-based config when the common normalizer lands.
RSS_SOURCE_URLS_JSON=[{"feedUrl":"https://www.youtube.com/feeds/videos.xml?channel_id=UCXZCJLdBC09xxGZ6gcdrc6A","sourceName":"OpenAI YouTube","sourceType":"youtube"}]

# LLM provider (score + summary)
# 02_enrich_with_llm will call ${LLM_BASE_URL}/chat/completions at runtime.
# Keep LLM_BASE_URL as the provider root, not the full chat/completions endpoint.
# LLM_PROVIDER is optional metadata for audit/debug and does not switch providers by itself.
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# Embedding provider
# Embeddings are independent from the chat LLM provider above.
# DeepSeek official docs currently document chat/completions APIs, so keep embeddings separate.
# Change EMBEDDING_MODEL and QDRANT_VECTOR_SIZE together. The example pair below is a known 1536-dim contract.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_INPUT_MAX_CHARS=6000
QDRANT_COLLECTION=article_embeddings
QDRANT_VECTOR_SIZE=1536
QDRANT_DIFF_THRESHOLD=0.85
QDRANT_SILENT_THRESHOLD=0.97
# Transcript service is vendored at ../services/VideoTranscriptAPI and builds locally by default.
VIDEO_TRANSCRIPT_IMAGE=ai-information-processor-video-transcript-api:local
VIDEO_TRANSCRIPT_HOST_PORT=18080
VIDEO_TRANSCRIPT_BASE_URL=http://video-transcript-api:8000
VIDEO_TRANSCRIPT_API_KEY=
MODEL_COMPARE_MODEL_KEYS=deepseek,doubao
MODEL_COMPARE_DEEPSEEK_API_KEY=
MODEL_COMPARE_DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
MODEL_COMPARE_DEEPSEEK_MODEL=deepseek-v4-flash
MODEL_COMPARE_DEEPSEEK_REASONING_EFFORT=
MODEL_COMPARE_DEEPSEEK_THINKING_TYPE=
MODEL_COMPARE_DOUBAO_API_KEY=
MODEL_COMPARE_DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
MODEL_COMPARE_DOUBAO_MODEL=
MODEL_COMPARE_DOUBAO_REASONING_EFFORT=
MODEL_COMPARE_DOUBAO_THINKING_TYPE=
COLLECTOR_WEB_IMAGE=ai-information-processor-collector-web:local
FUNASR_SPK_IMAGE=ai-information-processor-funasr-spk-server:local
FUNASR_SPK_PORT=8767
FUNASR_WEBHOOK_URL=
FUNASR_AUTH_SECRET_KEY=local-dev-secret-key
FUNASR_AUTH_ENABLED=false
FUNASR_NOTIFICATION_ENABLED=false
FUNASR_LOG_LEVEL=INFO
FUNASR_DEVICE=cpu
FUNASR_DEVICE_PRIORITY=cpu
FUNASR_NCPU=8
FUNASR_BATCH_SIZE_S=60
FUNASR_MAX_CONCURRENT_TASKS=1
FUNASR_TASK_TIMEOUT_MINUTES=60
FUNASR_TRANSCRIPTION_SPEED_RATIO=4
FUNASR_OMP_NUM_THREADS=4
PYTORCH_MPS_HIGH_WATERMARK_RATIO=0.0

# Feishu / im2memo
FEISHU_WEBHOOK_URL=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
IM2MEMO_MEMOS_TOKEN=
IM2MEMO_IMAGE=ghcr.io/zj1123581321/im2memo:latest
