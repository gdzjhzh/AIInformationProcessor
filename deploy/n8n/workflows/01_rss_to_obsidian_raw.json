                  {
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "language":  "javaScript",
                                         "jsCode":  "const config = $input.first()?.json || {};\nconst rawSourcesJson = (config.rssSourcesJson || \u0027\u0027).trim();\nconst fallbackSources = [\n  {\n    feedUrl: \u0027http://rsshub:1200/xiaoyuzhou/podcast/648b0b641c48983391a63f98\u0027,\n    sourceName: \u002742绔犵粡\u0027,\n    sourceType: \u0027podcast\u0027\n  }\n];\n\nlet sources = fallbackSources;\nif (rawSourcesJson) {\n  try {\n    const parsed = JSON.parse(rawSourcesJson);\n    if (!Array.isArray(parsed)) {\n      throw new Error(\u0027RSS_SOURCE_URLS_JSON must be a JSON array\u0027);\n    }\n    sources = parsed;\n  } catch (error) {\n    throw new Error(`RSS_SOURCE_URLS_JSON parse failed: ${error.message}`);\n  }\n}\n\nconst obsidianInboxDir = (config.obsidianInboxDir || \u002700_Inbox/AI_Information_Processor\u0027).trim() || \u002700_Inbox/AI_Information_Processor\u0027;\n\nreturn sources.map((source, index) =\u003e {\n  const feedUrl = (source.feedUrl || source.url || \u0027\u0027).trim();\n  if (!feedUrl) {\n    throw new Error(`Source ${index + 1} is missing feedUrl/url`);\n  }\n\n  const transcriptPollIntervalMs = Number(source.transcriptPollIntervalMs || 0);\n  const transcriptMaxPolls = Number(source.transcriptMaxPolls || 0);\n\n  return {\n    json: {\n      feedUrl,\n      sourceName: source.sourceName || source.name || `source-${index + 1}`,\n      sourceType: source.sourceType || \u0027rss\u0027,\n      routeToTranscript: typeof source.routeToTranscript === \u0027boolean\u0027 ? source.routeToTranscript : null,\n      useSpeakerRecognition: Boolean(source.useSpeakerRecognition),\n      transcriptPollIntervalMs: Number.isFinite(transcriptPollIntervalMs) ? transcriptPollIntervalMs : 0,\n      transcriptMaxPolls: Number.isFinite(transcriptMaxPolls) ? transcriptMaxPolls : 0,\n      obsidianInboxDir\n    }\n  };\n});"
                                     },
