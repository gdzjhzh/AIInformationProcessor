                  {
                      "parameters":  {
                                         "mode":  "runOnceForEachItem",
                                         "language":  "javaScript",
                                         "jsCode":  "const sourceContext = (() =\u003e {\n  try {\n    return $(\u0027Feed Sources\u0027).item.json || {};\n  } catch {\n    return {};\n  }\n})();\n\nconst rawHtml = [\n  $json[\u0027content:encoded\u0027],\n  $json.content,\n  $json.contentSnippet,\n  $json.summary,\n  $json.description\n].find((value) =\u003e typeof value === \u0027string\u0027 \u0026\u0026 value.trim()) || \u0027\u0027;\nconst description = [\n  $json.contentSnippet,\n  $json.summary,\n  $json.description\n].find((value) =\u003e typeof value === \u0027string\u0027 \u0026\u0026 value.trim()) || \u0027\u0027;\nconst sourceType = (sourceContext.sourceType || \u0027rss\u0027).trim() || \u0027rss\u0027;\nconst canonicalUrl = String($json.link || $json.guid || \u0027\u0027).trim();\nconst lowerSourceType = sourceType.toLowerCase();\n\nconst collectEnclosureCandidates = (value) =\u003e {\n  if (!value) {\n    return [];\n  }\n  if (typeof value === \u0027string\u0027) {\n    return [{ url: value.trim(), type: \u0027\u0027 }].filter((item) =\u003e item.url);\n  }\n  if (Array.isArray(value)) {\n    return value.flatMap(collectEnclosureCandidates);\n  }\n  if (typeof value === \u0027object\u0027) {\n    const url = [value.url, value.link, value.href, value.src]\n      .find((candidate) =\u003e typeof candidate === \u0027string\u0027 \u0026\u0026 candidate.trim()) || \u0027\u0027;\n    const type = [value.type, value.mimeType]\n      .find((candidate) =\u003e typeof candidate === \u0027string\u0027 \u0026\u0026 candidate.trim()) || \u0027\u0027;\n    return url ? [{ url: url.trim(), type: type.trim() }] : [];\n  }\n  return [];\n};\n\nconst enclosureCandidates = collectEnclosureCandidates($json.enclosure);\nconst audioEnclosure = enclosureCandidates.find((item) =\u003e /(^audio\\/)|\\.(mp3|m4a|aac|wav|ogg)(\\?|$)/i.test(`${item.type} ${item.url}`));\nconst transcriptSourceUrl = canonicalUrl || String(audioEnclosure?.url || \u0027\u0027).trim();\nconst isPodcastSource = [\u0027podcast\u0027, \u0027audio\u0027, \u0027podcast_rss\u0027].includes(lowerSourceType);\nconst isXiaoyuzhouEpisode = /https?:\\/\\/(?:www\\.)?xiaoyuzhoufm\\.com\\/episode\\//i.test(transcriptSourceUrl);\nconst explicitRouteToTranscript = typeof sourceContext.routeToTranscript === \u0027boolean\u0027\n  ? sourceContext.routeToTranscript\n  : null;\nconst routeToTranscript = explicitRouteToTranscript ?? Boolean(isPodcastSource || isXiaoyuzhouEpisode || audioEnclosure?.url);\nconst transcriptPollIntervalMs = Number(sourceContext.transcriptPollIntervalMs || 0);\nconst transcriptMaxPolls = Number(sourceContext.transcriptMaxPolls || 0);\nconst extraTags = [\u0027raw-ingest\u0027];\nif (routeToTranscript) {\n  extraTags.push(\u0027transcript-route\u0027);\n}\n\nreturn {\n  json: {\n    source_type: sourceType,\n    source_name: (sourceContext.sourceName || sourceContext.name || \u0027\u0027).trim(),\n    canonical_url: canonicalUrl,\n    original_id: String($json.guid || $json.id || $json.link || transcriptSourceUrl).trim(),\n    title: (($json.title || \u0027\u0027).trim() || \u0027untitled\u0027),\n    author: (($json.creator || $json.author || \u0027\u0027).trim()),\n    published_at: $json.isoDate || $json.pubDate || new Date().toISOString(),\n    media_type: routeToTranscript ? \u0027audio\u0027 : \u0027text\u0027,\n    raw_html: rawHtml,\n    raw_text: \u0027\u0027,\n    description,\n    transcript_source_url: transcriptSourceUrl,\n    download_url: String(audioEnclosure?.url || \u0027\u0027).trim(),\n    use_speaker_recognition: Boolean(sourceContext.useSpeakerRecognition),\n    obsidian_inbox_dir: sourceContext.obsidianInboxDir || $json.obsidianInboxDir || \u002700_Inbox/AI_Information_Processor\u0027,\n    extra_tags: extraTags,\n    route_to_transcript: routeToTranscript,\n    ...(transcriptPollIntervalMs \u003e 0 ? { poll_interval_ms: transcriptPollIntervalMs } : {}),\n    ...(transcriptMaxPolls \u003e 0 ? { max_polls: transcriptMaxPolls } : {}),\n    upstream_task_id: \u0027\u0027,\n    upstream_view_token: \u0027\u0027,\n    upstream_summary: \u0027\u0027,\n    original_item: $json\n  }\n};"
                                     },
