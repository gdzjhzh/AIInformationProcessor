                      "parameters":  {
                                         "mode":  "runOnceForEachItem",
                                         "language":  "javaScript",
                                         "jsCode":  "const transcriptText = String($json.transcript_text || $json.calibrated_transcript || \u0027\u0027).trim();\nif (!transcriptText) {\n  throw new Error(\u0027Resolved transcript payload is missing transcript_text\u0027);\n}\n\nconst obsidianInboxDir = String($json.obsidian_inbox_dir || $env.OBSIDIAN_INBOX_DIR || \u002700_Inbox/AI_Information_Processor\u0027).trim() || \u002700_Inbox/AI_Information_Processor\u0027;\n\nreturn {\n  json: {\n    source_type: String($json.source_type || \u0027transcript\u0027).trim() || \u0027transcript\u0027,\n    source_name: String($json.source_name || \u0027video-transcript-api\u0027).trim() || \u0027video-transcript-api\u0027,\n    canonical_url: String($json.canonical_url || $json.transcript_source_url || \u0027\u0027).trim(),\n    original_id: String($json.original_id || \u0027\u0027).trim(),\n    title: String($json.title || \u0027untitled\u0027).trim() || \u0027untitled\u0027,\n    author: String($json.author || \u0027\u0027).trim(),\n    published_at: $json.published_at || new Date().toISOString(),\n    media_type: String($json.media_type || \u0027video\u0027).trim() || \u0027video\u0027,\n    raw_html: \u0027\u0027,\n    raw_text: transcriptText,\n    obsidian_inbox_dir: obsidianInboxDir,\n    extra_tags: [\u0027transcript\u0027],\n    upstream_task_id: String($json.upstream_task_id || \u0027\u0027).trim(),\n    upstream_view_token: String($json.upstream_view_token || \u0027\u0027).trim(),\n    upstream_summary: String($json.upstream_summary || \u0027\u0027).trim(),\n    original_item: $json.original_item ?? $json\n  }\n};"
