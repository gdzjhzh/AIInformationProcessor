                      "id":  "53c35a87-d018-4470-b16a-3c219a38cc52",
                      "name":  "Example Transcript Request",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       520,
                                       180
                                   ]
                  },
                  {
                      "parameters":  {
                                         "mode":  "runOnceForEachItem",
                                         "language":  "javaScript",
                                         "jsCode":  "const sourceUrl = String($json.transcript_source_url || $json.url || \u0027\u0027).trim();\nif (!sourceUrl) {\n  throw new Error(\u0027transcript_source_url is required for 04_video_transcript_ingest\u0027);\n}\n\nconst baseUrl = String($env.VIDEO_TRANSCRIPT_BASE_URL || \u0027\u0027).trim().replace(/\\/+$/, \u0027\u0027);\nconst apiKey = String($env.VIDEO_TRANSCRIPT_API_KEY || \u0027\u0027).trim();\nif (!baseUrl) {\n  throw new Error(\u0027VIDEO_TRANSCRIPT_BASE_URL is required for 04_video_transcript_ingest\u0027);\n}\nif (!apiKey) {\n  throw new Error(\u0027VIDEO_TRANSCRIPT_API_KEY is required for 04_video_transcript_ingest\u0027);\n}\n\nconst metadataOverride = {};\nfor (const [sourceKey, targetKey] of [\n  [\u0027title\u0027, \u0027title\u0027],\n  [\u0027author\u0027, \u0027author\u0027],\n  [\u0027description\u0027, \u0027description\u0027]\n]) {\n  const value = String($json[sourceKey] || \u0027\u0027).trim();\n  if (value) {\n    metadataOverride[targetKey] = value;\n  }\n}\n\nconst requestBody = {\n  url: sourceUrl,\n  use_speaker_recognition: Boolean($json.use_speaker_recognition),\n};\n\nconst downloadUrl = String($json.download_url || \u0027\u0027).trim();\nif (downloadUrl) {\n  requestBody.download_url = downloadUrl;\n}\n\nconst wechatWebhook = String($json.wechat_webhook || \u0027\u0027).trim();\nif (wechatWebhook) {\n  requestBody.wechat_webhook = wechatWebhook;\n}\n\nif (Object.keys(metadataOverride).length) {\n  requestBody.metadata_override = metadataOverride;\n}\n\nreturn {\n  json: {\n    ...$json,\n    transcript_source_url: sourceUrl,\n    transcript_api: {\n      base_url: baseUrl,\n      api_key: apiKey,\n      submit_url: `${baseUrl}/api/transcribe`,\n      request_body: requestBody,\n      poll_interval_ms: Math.max(1000, Number($json.poll_interval_ms || 3000)),\n      max_polls: Math.max(1, Number($json.max_polls || 40))\n    }\n  }\n};"
                                     },
