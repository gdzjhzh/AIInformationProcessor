                      "id":  "9f980fee-f771-49b6-ad44-8c56a33194e8",
                      "name":  "Fetch Transcript Task Status",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       1820,
                                       280
                                   ]
                  },
                  {
                      "parameters":  {
                                         "mode":  "runOnceForEachItem",
                                         "language":  "javaScript",
                                         "jsCode":  "const context = $(\u0027Prepare Transcript Task Status Request\u0027).item.json || {};\nconst taskStatus = $json || {};\nconst maxPolls = Math.max(1, Number(context.transcript_api?.max_polls || 40));\nconst nextAttempt = Number(context.poll_attempt || 0) + 1;\nconst responseCode = Number(taskStatus.code || 0);\n\nif (!Number.isFinite(responseCode)) {\n  throw new Error(`Transcript API task status returned a non-numeric code: ${JSON.stringify(taskStatus)}`);\n}\n\nif (responseCode === 202) {\n  if (nextAttempt \u003e= maxPolls) {\n    throw new Error(`Transcript API task ${context.upstream_task_id || \u0027unknown\u0027} did not finish within ${maxPolls} polls`);\n  }\n\n  return {\n    json: {\n      ...context,\n      poll_attempt: nextAttempt,\n      poll_state: \u0027pending\u0027,\n      transcript_status: String(taskStatus.message || \u0027\u0027).trim()\n    }\n  };\n}\n\nif (responseCode \u003e= 500) {\n  throw new Error(`Transcript API task ${context.upstream_task_id || \u0027unknown\u0027} failed: ${taskStatus.message || \u0027unknown error\u0027}`);\n}\n\nconst taskData = taskStatus.data \u0026\u0026 typeof taskStatus.data === \u0027object\u0027 ? taskStatus.data : {};\nconst transcriptText = String(taskData.transcript || \u0027\u0027).trim();\nif (!transcriptText) {\n  throw new Error(`Transcript API task ${context.upstream_task_id || \u0027unknown\u0027} completed without transcript text`);\n}\n\nreturn {\n  json: {\n    ...context,\n    poll_attempt: nextAttempt,\n    poll_state: \u0027completed\u0027,\n    upstream_summary: String(context.upstream_summary || \u0027\u0027).trim(),\n    canonical_url: String(context.canonical_url || context.transcript_source_url || \u0027\u0027).trim(),\n    original_id: String(context.original_id || `video-transcript:${context.upstream_view_token || \u0027unknown\u0027}`).trim(),\n    title: String(taskData.video_title || context.title || \u0027untitled transcript item\u0027).trim() || \u0027untitled transcript item\u0027,\n    author: String(taskData.author || context.author || \u0027\u0027).trim(),\n    published_at: context.published_at || new Date().toISOString(),\n    transcript_text: transcriptText,\n    transcript_status: String(taskStatus.message || \u0027\u0027).trim(),\n    original_item: {\n      request: context.transcript_api?.request_body || {},\n      submit_response: context.submit_response || {},\n      task_status: taskStatus\n    }\n  }\n};"
                                     },
