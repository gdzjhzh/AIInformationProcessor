                                         "jsCode":  "if (!String($json.task_status_url || \u0027\u0027).trim()) {\n  throw new Error(\u0027task_status_url is required before polling Transcript API task status\u0027);\n}\n\nreturn {\n  json: {\n    ...$json\n  }\n};"
                                     },
