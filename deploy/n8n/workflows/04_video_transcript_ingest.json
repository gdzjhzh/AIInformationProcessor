                      "id":  "0ff8c82d-dcc2-4b3b-a4e7-4ed53baef645",
                      "name":  "Submit Transcript Task",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       1040,
                                       280
                                   ]
                  },
                  {
                      "parameters":  {
                                         "mode":  "runOnceForEachItem",
                                         "language":  "javaScript",
                                         "jsCode":  "const requestItem = $(\u0027Build Transcript API Request\u0027).item.json || {};\nconst submitResponse = $json || {};\nconst transcriptApi = requestItem.transcript_api || {};\nconst baseUrl = String(transcriptApi.base_url || \u0027\u0027).replace(/\\/+$/, \u0027\u0027);\nconst apiKey = String(transcriptApi.api_key || \u0027\u0027).trim();\nconst taskId = String(submitResponse?.data?.task_id || \u0027\u0027).trim();\nconst viewToken = String(submitResponse?.data?.view_token || \u0027\u0027).trim();\n\nif (!baseUrl || !apiKey) {\n  throw new Error(\u0027Transcript API connection info is missing after submission\u0027);\n}\nif (!taskId || !viewToken) {\n  throw new Error(`Transcript API submit response missing task_id/view_token: ${JSON.stringify(submitResponse)}`);\n}\n\nreturn {\n  json: {\n    ...requestItem,\n    submit_response: submitResponse,\n    upstream_task_id: taskId,\n    upstream_view_token: viewToken,\n    poll_attempt: 0,\n    poll_state: \u0027pending\u0027,\n    task_status_url: `${baseUrl}/api/task/${encodeURIComponent(taskId)}`,\n    transcript_exports: {\n      calibrated: `${baseUrl}/view/${viewToken}?raw=calibrated`,\n      transcript: `${baseUrl}/view/${viewToken}?raw=transcript`,\n      summary: `${baseUrl}/view/${viewToken}?raw=summary`\n    }\n  }\n};"
                                     },
                      "id":  "98a3ca8f-4245-41f0-8b02-7ec6b988db53",
