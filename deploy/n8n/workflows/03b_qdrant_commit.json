                                         "jsCode":  "const toDeterministicUuid = (value) =\u003e {\n  const hex = String(value || \u0027\u0027).toLowerCase().replace(/[^0-9a-f]/g, \u0027\u0027);\n  const padded = (hex + \u002700000000000000000000000000000000\u0027).slice(0, 32);\n  return `${padded.slice(0, 8)}-${padded.slice(8, 12)}-${padded.slice(12, 16)}-${padded.slice(16, 20)}-${padded.slice(20, 32)}`;\n};\n\nconst vaultWriteStatus = String($json.vault_write_status || $json.vault_write || \u0027\u0027).trim();\nconst qdrantBaseUrl = String($json.qdrant_base_url || \u0027http://qdrant:6333\u0027).trim().replace(/\\/*$/, \u0027\u0027);\nconst qdrantCollection = String($json.qdrant_collection || \u0027\u0027).trim();\nconst embedding = Array.isArray($json.embedding) ? $json.embedding : [];\nconst shouldCommitQdrant = vaultWriteStatus === \u0027written\u0027\n  \u0026\u0026 Boolean($json.should_upsert_qdrant)\n  \u0026\u0026 qdrantBaseUrl\n  \u0026\u0026 qdrantCollection\n  \u0026\u0026 embedding.length \u003e 0;\nconst qdrantPointId = String($json.qdrant_point_id || \u0027\u0027).trim() || toDeterministicUuid($json.item_id);\n\nreturn {\n  json: {\n    ...$json,\n    qdrant_point_id: qdrantPointId,\n    qdrant_upsert_endpoint: shouldCommitQdrant\n      ? `${qdrantBaseUrl}/collections/${encodeURIComponent(qdrantCollection)}/points`\n      : String($json.qdrant_upsert_endpoint || \u0027\u0027).trim(),\n    qdrant_upsert_payload: shouldCommitQdrant\n      ? {\n          points: [\n            {\n              id: qdrantPointId,\n              vector: embedding,\n              payload: {\n                item_id: $json.item_id,\n                source_type: $json.source_type,\n                source_name: $json.source_name,\n                title: $json.title,\n                canonical_url: $json.canonical_url,\n                published_at: $json.published_at,\n                score: $json.score,\n                category: $json.category,\n                summary: $json.summary,\n                dedupe_action: $json.dedupe_action,\n                matched_score: $json.matched_score,\n                tags: $json.tags,\n                content_hash: $json.content_hash\n              }\n            }\n          ]\n        }\n      : ($json.qdrant_upsert_payload ?? null),\n    should_commit_qdrant: shouldCommitQdrant,\n    qdrant_operation: shouldCommitQdrant ? \u0027pending\u0027 : \u0027skipped\u0027,\n    qdrant_upsert_response: shouldCommitQdrant ? null : ($json.qdrant_upsert_response ?? null)\n  }\n};"
