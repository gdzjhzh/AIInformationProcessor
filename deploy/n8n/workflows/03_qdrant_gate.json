                  {
                      "parameters":  {
                                         "mode":  "runOnceForEachItem",
                                         "language":  "javaScript",
                                         "jsCode":  "const original = $(\u0027Build Embedding Request\u0027).item.json || {};\nconst embedding = $json?.data?.[0]?.embedding;\nif (!Array.isArray(embedding)) {\n  throw new Error(\u0027Embedding response did not include data[0].embedding\u0027);\n}\nif (embedding.length !== Number(original.qdrant_vector_size)) {\n  throw new Error(`Embedding vector length ${embedding.length} does not match QDRANT_VECTOR_SIZE ${original.qdrant_vector_size}`);\n}\n\nreturn {\n  json: {\n    ...original,\n    embedding,\n    qdrant_search_endpoint: `${original.qdrant_base_url}/collections/${encodeURIComponent(original.qdrant_collection)}/points/search`,\n    qdrant_search_payload: {\n      vector: embedding,\n      limit: 1,\n      with_payload: true\n    }\n  }\n};"
                                     },
