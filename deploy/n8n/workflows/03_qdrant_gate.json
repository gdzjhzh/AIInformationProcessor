                                         "jsCode":  "return [\n  {\n    json: {\n      item_id: \u00276d6e2f96ab2c4f86c6bfe17f0f3d5c21d7839ed4f3d8fbf35bc7f7f5ec34f7a1\u0027,\n      source_type: \u0027rss\u0027,\n      source_name: \u0027OpenAI YouTube\u0027,\n      canonical_url: \u0027https://example.com/post\u0027,\n      title: \u0027Example normalized item before LLM enrichment\u0027,\n      author: \u0027OpenAI\u0027,\n      published_at: \u00272026-04-17T09:00:00-04:00\u0027,\n      ingested_at: \u00272026-04-17T09:05:00-04:00\u0027,\n      media_type: \u0027text\u0027,\n      content_text: \u0027Normalized plain text content for vector search. The item explains why AIInformationProcessor should establish a stable text-object contract before adding more ingestion paths.\u0027,\n      content_hash: \u0027sha256:example\u0027,\n      upstream_summary: \u0027\u0027,\n      search_text: \u0027Example normalized item before LLM enrichment\\n\\nNormalized plain text content for vector search. The item explains why AIInformationProcessor should establish a stable text-object contract before adding more ingestion paths.\u0027,\n      dedupe_action: \u0027full_push\u0027,\n      status: \u0027raw\u0027\n    }\n  }\n];"
                                     },
                      "id":  "1ac5c46d-dace-4d4b-bce3-6978be3a3b8f",
                      "name":  "Example Enriched Item",
