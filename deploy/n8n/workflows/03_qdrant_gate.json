                  {
                      "parameters":  {
                                         "mode":  "runOnceForEachItem",
                                         "language":  "javaScript",
                                         "jsCode":  "const requiredFields = [\u0027item_id\u0027, \u0027source_type\u0027, \u0027source_name\u0027, \u0027title\u0027, \u0027content_text\u0027];\nconst missingFields = requiredFields.filter((field) =\u003e !String($json[field] || \u0027\u0027).trim());\nif (missingFields.length) {\n  throw new Error(`Normalized item missing required fields: ${missingFields.join(\u0027, \u0027)}`);\n}\n\nconst embeddingBaseUrl = String($env.EMBEDDING_BASE_URL || \u0027\u0027).trim().replace(/\\/*$/, \u0027\u0027);\nconst embeddingModel = String($env.EMBEDDING_MODEL || \u0027\u0027).trim();\nconst embeddingApiKey = String($env.EMBEDDING_API_KEY || \u0027\u0027).trim();\nconst embeddingInputMaxChars = Number($env.EMBEDDING_INPUT_MAX_CHARS || 8000);\nconst qdrantCollection = String($env.QDRANT_COLLECTION || \u0027article_embeddings\u0027).trim() || \u0027article_embeddings\u0027;\nconst qdrantVectorSize = Number($env.QDRANT_VECTOR_SIZE || 0);\nconst diffThreshold = Number($env.QDRANT_DIFF_THRESHOLD || 0.85);\nconst silentThreshold = Number($env.QDRANT_SILENT_THRESHOLD || 0.97);\nconst searchText = String($json.search_text || [\n  String($json.title || \u0027\u0027).trim(),\n  String($json.upstream_summary || \u0027\u0027).trim(),\n  String($json.content_text || \u0027\u0027).trim()\n].filter(Boolean).join(\u0027\\n\\n\u0027)).trim().slice(0, embeddingInputMaxChars);\n\nif (!embeddingBaseUrl) {\n  throw new Error(\u0027EMBEDDING_BASE_URL is required for 03_qdrant_gate\u0027);\n}\nif (!embeddingModel) {\n  throw new Error(\u0027EMBEDDING_MODEL is required for 03_qdrant_gate\u0027);\n}\nif (!embeddingApiKey) {\n  throw new Error(\u0027EMBEDDING_API_KEY is required for 03_qdrant_gate\u0027);\n}\nif (!Number.isInteger(embeddingInputMaxChars) || embeddingInputMaxChars \u003c 200) {\n  throw new Error(\u0027EMBEDDING_INPUT_MAX_CHARS must be an integer \u003e= 200\u0027);\n}\nif (!Number.isInteger(qdrantVectorSize) || qdrantVectorSize \u003c= 0) {\n  throw new Error(\u0027QDRANT_VECTOR_SIZE must be a positive integer\u0027);\n}\nif (!Number.isFinite(diffThreshold) || !Number.isFinite(silentThreshold)) {\n  throw new Error(\u0027QDRANT_DIFF_THRESHOLD and QDRANT_SILENT_THRESHOLD must be numeric\u0027);\n}\nif (!(diffThreshold \u003e 0 \u0026\u0026 diffThreshold \u003c silentThreshold \u0026\u0026 silentThreshold \u003c= 1)) {\n  throw new Error(\u0027Expected 0 \u003c QDRANT_DIFF_THRESHOLD \u003c QDRANT_SILENT_THRESHOLD \u003c= 1\u0027);\n}\nif (searchText.length \u003c 80) {\n  throw new Error(\u0027search_text is too short for reliable dedupe; expected at least 80 characters after prefilter\u0027);\n}\n\nreturn {\n  json: {\n    ...$json,\n    embedding_base_url: embeddingBaseUrl,\n    embedding_model: embeddingModel,\n    embedding_input_max_chars: embeddingInputMaxChars,\n    qdrant_base_url: \u0027http://qdrant:6333\u0027,\n    qdrant_collection: qdrantCollection,\n    qdrant_vector_size: qdrantVectorSize,\n    qdrant_diff_threshold: diffThreshold,\n    qdrant_silent_threshold: silentThreshold,\n    embedding_input: searchText,\n    search_text: searchText\n  }\n};"
                                     },
