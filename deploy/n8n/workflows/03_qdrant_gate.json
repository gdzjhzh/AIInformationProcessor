                      "id":  "6d6ac0dd-b8c4-4cb8-88d9-2fd319277ea3",
                      "name":  "Qdrant Search",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       1820,
                                       240
                                   ]
                  },
                  {
                      "parameters":  {
                                         "mode":  "runOnceForEachItem",
                                         "language":  "javaScript",
                                         "jsCode":  "const original = $(\u0027Build Qdrant Search Request\u0027).item.json || {};\nconst matches = Array.isArray($json?.result)\n  ? $json.result\n  : Array.isArray($json)\n    ? $json\n    : [];\nconst match = matches[0] || null;\nconst matchedPayload = match?.payload || null;\nconst matchedScore = Number(match?.score || 0);\nconst sameItem = Boolean(matchedPayload \u0026\u0026 matchedPayload.item_id === original.item_id);\nconst sameContent = Boolean(sameItem \u0026\u0026 matchedPayload.content_hash === original.content_hash);\n\nlet dedupeAction = \u0027full_push\u0027;\nif (sameContent) {\n  dedupeAction = \u0027silent\u0027;\n} else if (sameItem) {\n  dedupeAction = \u0027diff_push\u0027;\n} else if (match \u0026\u0026 matchedScore \u003e= Number(original.qdrant_silent_threshold)) {\n  dedupeAction = \u0027silent\u0027;\n} else if (match \u0026\u0026 matchedScore \u003e= Number(original.qdrant_diff_threshold)) {\n  dedupeAction = \u0027diff_push\u0027;\n}\n\nconst shouldContinueToLlm = dedupeAction !== \u0027silent\u0027;\nconst notificationMode = dedupeAction === \u0027silent\u0027\n  ? \u0027silent\u0027\n  : dedupeAction === \u0027diff_push\u0027\n    ? \u0027incremental\u0027\n    : \u0027full\u0027;\n\nreturn {\n  json: {\n    ...original,\n    dedupe_action: dedupeAction,\n    notification_mode: notificationMode,\n    should_continue_to_llm: shouldContinueToLlm,\n    should_write_to_vault: shouldContinueToLlm,\n    should_notify: shouldContinueToLlm,\n    should_upsert_qdrant: shouldContinueToLlm,\n    matched_payload: matchedPayload,\n    matched_score: matchedScore,\n    matched_same_item: sameItem,\n    matched_same_content: sameContent,\n    status: dedupeAction === \u0027silent\u0027 ? \u0027deduped\u0027 : (String(original.status || \u0027raw\u0027).trim() || \u0027raw\u0027),\n    qdrant_operation: shouldContinueToLlm ? \u0027pending\u0027 : \u0027skipped\u0027,\n    qdrant_upsert_response: null\n  }\n};"
                                     },
