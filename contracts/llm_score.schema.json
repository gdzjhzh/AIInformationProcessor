{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiinformationprocessor.local/contracts/llm_score.schema.json",
  "title": "LlmScore",
  "description": "Structured enrichment fragment emitted by 02_enrich_with_llm before downstream policy and write steps.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "score",
    "score_scale",
    "category",
    "tags",
    "summary",
    "reason",
    "signals",
    "event_delta",
    "ai_score",
    "score_dimensions",
    "ai_meta",
    "enriched_at",
    "status"
  ],
  "properties": {
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Compatibility normalized score. Must equal ai_score.keep_score / score_scale."
    },
    "score_scale": {
      "type": "integer",
      "const": 100,
      "description": "Canonical score scale for ai_score.keep_score. Must remain 100."
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "signals": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "signal",
          "signal_type",
          "evidence_anchor",
          "confidence",
          "why_it_matters"
        ],
        "properties": {
          "signal": {
            "type": "string",
            "minLength": 1
          },
          "signal_type": {
            "type": "string",
            "enum": [
              "industry_shift",
              "strategy_hint",
              "technical_pattern",
              "market_signal",
              "risk_signal",
              "workflow_signal"
            ]
          },
          "evidence_anchor": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "why_it_matters": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "ai_score": {
      "type": "object",
      "required": [
        "keep_score",
        "notify_score",
        "reference_score",
        "action_score",
        "confidence",
        "decision_hint"
      ],
      "properties": {
        "keep_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Canonical keep score on a 0-100 scale. Top-level score must equal keep_score / score_scale."
        },
        "notify_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "reference_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "action_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "decision_hint": {
          "type": "string",
          "enum": [
            "keep_full",
            "keep_reference",
            "review",
            "skip"
          ]
        }
      },
      "additionalProperties": false
    },
    "score_dimensions": {
      "type": "object",
      "required": [
        "personal_relevance",
        "information_density",
        "novelty",
        "actionability",
        "long_term_value",
        "source_quality",
        "penalty"
      ],
      "properties": {
        "personal_relevance": {
          "type": "integer",
          "minimum": 0,
          "maximum": 25
        },
        "information_density": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20
        },
        "novelty": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20
        },
        "actionability": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15
        },
        "long_term_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15
        },
        "source_quality": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "penalty": {
          "type": "integer",
          "minimum": -20,
          "maximum": 0
        }
      },
      "additionalProperties": false
    },
    "ai_meta": {
      "type": "object",
      "required": [
        "model_profile",
        "provider",
        "model",
        "prompt_version",
        "rubric_version",
        "input_chars",
        "scored_at"
      ],
      "properties": {
        "model_profile": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "prompt_version": {
          "type": "string",
          "minLength": 1
        },
        "rubric_version": {
          "type": "string",
          "minLength": 1
        },
        "input_chars": {
          "type": "integer",
          "minimum": 1
        },
        "scored_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "enriched_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "enriched"
      ]
    },
    "event_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation",
        "compared_item_id",
        "compared_title",
        "compared_summary",
        "delta_summary",
        "delta_facts",
        "delta_viewpoints",
        "contradictions",
        "delta_importance",
        "should_delta_notify"
      ],
      "properties": {
        "relation": {
          "type": "string",
          "enum": [
            "new_event",
            "same_event_delta",
            "same_event_repeat",
            "related_topic",
            "uncertain"
          ]
        },
        "compared_item_id": {
          "type": "string"
        },
        "compared_title": {
          "type": "string"
        },
        "compared_summary": {
          "type": "string"
        },
        "delta_summary": {
          "type": "string"
        },
        "delta_facts": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "delta_viewpoints": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "contradictions": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "delta_importance": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "should_delta_notify": {
          "type": "boolean"
        }
      }
    }
  }
}
