{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiinformationprocessor.local/contracts/normalized_text_object.schema.json",
  "title": "NormalizedTextObject",
  "description": "Machine-readable contract for the shared Stage-0 ingress baseline emitted by 00_common_normalize_text_object before enrichment, dedupe, and write-time fragments are attached.",
  "type": "object",
  "additionalProperties": false,
  "x-forbiddenProperties": [
    "obsidian_inbox_dir",
    "raw_text",
    "raw_html",
    "transcript_text",
    "calibrated_transcript",
    "action"
  ],
  "x-canonicalMappings": {
    "obsidian_inbox_dir": "obsidianInboxDir",
    "raw_text": "content_text",
    "raw_html": "content_html",
    "transcript_text": "content_text",
    "calibrated_transcript": "content_text"
  },
  "required": [
    "item_id",
    "source_type",
    "source_name",
    "source_host",
    "original_id",
    "canonical_url",
    "title",
    "author",
    "published_at",
    "ingested_at",
    "media_type",
    "content_text",
    "content_html",
    "upstream_task_id",
    "upstream_view_token",
    "upstream_summary",
    "content_hash",
    "tags",
    "obsidianInboxDir"
  ],
  "properties": {
    "item_id": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "minLength": 1
    },
    "source_name": {
      "type": "string",
      "minLength": 1
    },
    "source_host": {
      "type": "string",
      "minLength": 1
    },
    "original_id": {
      "type": "string"
    },
    "canonical_url": {
      "type": "string",
      "minLength": 1,
      "format": "uri"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string"
    },
    "published_at": {
      "type": "string",
      "format": "date-time"
    },
    "ingested_at": {
      "type": "string",
      "format": "date-time"
    },
    "media_type": {
      "type": "string",
      "minLength": 1
    },
    "content_text": {
      "type": "string",
      "minLength": 1
    },
    "content_html": {
      "type": "string"
    },
    "upstream_task_id": {
      "type": "string"
    },
    "upstream_view_token": {
      "type": "string"
    },
    "upstream_summary": {
      "type": "string"
    },
    "content_hash": {
      "type": "string",
      "minLength": 1,
      "pattern": "^sha256:"
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "obsidianInboxDir": {
      "type": "string",
      "minLength": 1
    },
    "original_item": {}
  }
}
